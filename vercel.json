{
  "version": 2,
  "buildCommand": null,
  "outputDirectory": ".",
  "rewrites": [
    { "source": "/", "destination": "/pages/index.html" },
    { "source": "/marketplace", "destination": "/pages/marketplace.html" },
    { "source": "/search", "destination": "/pages/search.html" },
    { "source": "/product", "destination": "/pages/product.html" },
    { "source": "/checkout", "destination": "/pages/checkout.html" },
    { "source": "/login", "destination": "/pages/auth/login.html" },
    { "source": "/signup", "destination": "/pages/auth/signup.html" },
    { "source": "/reset", "destination": "/pages/auth/reset.html" },
    { "source": "/buyer/dashboard", "destination": "/pages/buyer/dashboard.html" },
    { "source": "/buyer/library", "destination": "/pages/buyer/library.html" },
    { "source": "/buyer/wishlist", "destination": "/pages/buyer/wishlist.html" },
    { "source": "/buyer/orders", "destination": "/pages/buyer/orders.html" },
    { "source": "/seller/dashboard", "destination": "/pages/seller/dashboard.html" },
    { "source": "/seller/products", "destination": "/pages/seller/products.html" },
    { "source": "/seller/new", "destination": "/pages/seller/new-product.html" },
    { "source": "/seller/analytics", "destination": "/pages/seller/analytics.html" },
    { "source": "/seller/payouts", "destination": "/pages/seller/payouts.html" },
    { "source": "/seller/affiliates", "destination": "/pages/seller/affiliates.html" },
    { "source": "/seller/discounts", "destination": "/pages/seller/discount-codes.html" },
    { "source": "/seller/bundles", "destination": "/pages/seller/bundles.html" },
    { "source": "/seller/settings", "destination": "/pages/seller/settings.html" },
    { "source": "/admin/dashboard", "destination": "/pages/admin/dashboard.html" },
    { "source": "/admin/listings", "destination": "/pages/admin/listings.html" },
    { "source": "/admin/users", "destination": "/pages/admin/users.html" },
    { "source": "/admin/disputes", "destination": "/pages/admin/disputes.html" },
    { "source": "/s/:username", "destination": "/pages/storefront/index.html" }
  ],
  "headers": [
    {
      "version": 2,
      "outputDirectory": ".",
      "rewrites": [
        { "source": "/", "destination": "/pages/index.html" },
        { "source": "/marketplace", "destination": "/pages/marketplace.html" },
        { "source": "/search", "destination": "/pages/search.html" },
        { "source": "/product", "destination": "/pages/product.html" },
        { "source": "/checkout", "destination": "/pages/checkout.html" },
        { "source": "/login", "destination": "/pages/auth/login.html" },
        { "source": "/signup", "destination": "/pages/auth/signup.html" },
        { "source": "/reset", "destination": "/pages/auth/reset.html" },
        { "source": "/buyer/dashboard", "destination": "/pages/buyer/dashboard.html" },
        { "source": "/buyer/library", "destination": "/pages/buyer/library.html" },
        { "source": "/buyer/wishlist", "destination": "/pages/buyer/wishlist.html" },
        { "source": "/buyer/orders", "destination": "/pages/buyer/orders.html" },
        { "source": "/buyer/profile", "destination": "/pages/buyer/profile.html" },
        { "source": "/seller/dashboard", "destination": "/pages/seller/dashboard.html" },
        { "source": "/seller/products", "destination": "/pages/seller/products.html" },
        { "source": "/seller/new", "destination": "/pages/seller/new-product.html" },
        { "source": "/seller/analytics", "destination": "/pages/seller/analytics.html" },
        { "source": "/seller/payouts", "destination": "/pages/seller/payouts.html" },
        { "source": "/seller/affiliates", "destination": "/pages/seller/affiliates.html" },
        { "source": "/seller/discounts", "destination": "/pages/seller/discount-codes.html" },
        { "source": "/seller/bundles", "destination": "/pages/seller/bundles.html" },
        { "source": "/seller/settings", "destination": "/pages/seller/settings.html" },
        { "source": "/admin/dashboard", "destination": "/pages/admin/dashboard.html" },
        { "source": "/admin/listings", "destination": "/pages/admin/listings.html" },
        { "source": "/admin/users", "destination": "/pages/admin/users.html" },
        { "source": "/admin/disputes", "destination": "/pages/admin/disputes.html" },
        { "source": "/admin/revenue", "destination": "/pages/admin/revenue.html" },
        { "source": "/s/:username", "destination": "/pages/storefront/index.html" }
      ],
      "headers": [
        {
          "source": "/(.*)",
          "headers": [
            { "key": "Access-Control-Allow-Origin", "value": "*" },
            { "key": "Access-Control-Allow-Methods", "value": "GET, POST, OPTIONS" },
            { "key": "Access-Control-Allow-Headers", "value": "Content-Type, Authorization" }
          ]
        }
      ]
    }
